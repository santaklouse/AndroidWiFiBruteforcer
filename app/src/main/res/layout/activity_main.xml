<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Индикатор состояния -->
    <TextView
        android:id="@+id/tvServiceStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:text="Сервис остановлен"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="#FFCCCC"
        android:textColor="#D32F2F" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Запустить сканирование" />

        <Button
            android:id="@+id/btnStop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Остановить" />

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerNetworks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp" />

    <!-- Блок логов -->
    <TextView
        android:id="@+id/tvLogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="▼ Логи сервиса"
        android:textSize="16sp"
        android:textStyle="bold"
        android:padding="8dp"
        android:background="#E0E0E0"
        android:clickable="true" />

    <ScrollView
        android:id="@+id/scrollLogs"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:background="#F5F5F5" />
    </ScrollView>

</LinearLayout>